@page "/about"
@rendermode InteractiveServer

@inject ContactService ContactService

<PageTitle>About Me</PageTitle>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8">
    <section class="grid gap-10 lg:items-start">
      <div>
        <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-400">
          About Me
        </p>
      </div>
    </section>
    <section>
      <!-- Right column -->
      <aside class="lg:sticky lg:top-8 mt-8">
        <div class="overflow-hidden rounded-3xl border border-slate-800 bg-slate-900/60 shadow-xl shadow-black/20">
          <div class="flex flex-col lg:flex-row">
             <!-- Photo -->
            <div class="shrink-0 bg-slate-800">
              <img src="/images/prof_pic.jpg" alt="Photo of Julio Gonzalez Garcia"
                   class="h-[33rem] w-[25rem] object-cover" />
            </div>
            <!-- Details -->
            <div class="flex-1 p-8">
              <h2 class="text-2xl font-semibold text-white">Julio Gonzalez Garcia</h2>
              <p class="mt-2 text-sm text-slate-400">Full-Stack Systems & Data Engineer</p>

              <div class="mt-6 space-y-6 text-sm leading-7 text-slate-300">
                <p>
                  I build reliable systems, web applications, and automation tools with a focus on maintainability and
                  practical impact.
                </p>

                <p>
                  My background includes full-stack development, system analysis, SQL Server and Oracle environments,
                  backend services, and workflow automation across business-critical applications.
                </p>

                <p>
                  I enjoy working in C#, .NET, Python, SQL, and modern web frameworks like Blazor, React, and Next.js.
                  I like building software that is clean, useful, and easy to evolve over time.
                </p>

                <div class="pt-2">
                  <h3 class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-400">
                    Core Skills
                  </h3>
                  <p class="mt-3 text-slate-300">
                    C#, .NET, Blazor, Python, SQL, SQL Server, Oracle, TypeScript, React, Next.js, PowerShell, Bash,
                    Docker, IIS
                  </p>
                </div>

                <div class="mt-6 flex flex-wrap items-center gap-4">
                  <button type="button"
                          class="rounded-xl border border-slate-700 bg-slate-800 px-5 py-3 font-semibold text-slate-100 transition hover:bg-slate-700"
                          @onclick="RevealEmailAsync">
                    Contact Me!
                  </button>

                  @if (!string.IsNullOrWhiteSpace(Email))
                  {
                    <a href="mailto:@Email"
                       class="rounded-xl bg-cyan-500 px-5 py-3 font-semibold text-slate-950 transition hover:bg-cyan-400">
                      @Email
                    </a>
                  }
                  else
                  {
                    <span class="select-none rounded-xl border border-slate-800 bg-slate-950/60 px-5 py-3 text-slate-400">
                      <span class="blur-md opacity-60 tracking-widest">
                          hey!.shhhhhh-keepthissecret
                      </span>
                  </span>
                  }
                </div>

              </div>
            </div>
          </div>
        </div>
      </aside>
    </section>

    <!-- Timeline -->
    <section class="mt-8">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-400">
            Timeline
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white">
            A quick look at my background
          </h2>
        </div>
      </div>

      <div class="mt-8 space-y-6">
        @foreach (var item in Timeline)
        {
          <article
            class="grid gap-4 rounded-2xl border border-slate-800 bg-slate-900/60 p-6 lg:grid-cols-[180px_1fr] lg:gap-8 mt-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-400">
                @item.Date
              </p>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-white">@item.Title</h3>
              <p class="mt-2 leading-7 text-slate-300">@item.Description</p>
            </div>
          </article>
        }
      </div>
    </section>
  </div>
</div>

@code {
  private readonly List<TimelineItem> Timeline =
  [
    new(
      "Dec 2023 – Present",
      "County of Santa Barbara",
      "EDP Systems and Programming Analyst I. Focused on full-stack application development, .NET refactoring, database engineering, automation, and systems integration."
    ),
    new(
      "Sep 2021 – Dec 2023",
      "Santa Maria Joint Union High School",
      "Student Information Systems Analyst. Supported and maintained large-scale SIS environments, worked on data integration, reporting, troubleshooting, and process improvements."
    ),
    new(
      "Jun 2021",
      "California Polytechnic State University",
      "Earned a Bachelor of Science in Computer Science with coursework in software engineering, databases, algorithms, and technical writing."
    )
  ];

  private record TimelineItem(string Date, string Title, string Description);

  private string Email = "";

  private Task RevealEmailAsync()
  {
    Email = ContactService.GetEmail();
    return Task.CompletedTask;
  }
}