@using Microsoft.AspNetCore.Components.Web

@if (IsOpen && CurrentPet is not null)
{
  <div class="pet-preview-popover" style="@PopoverStyle" @ref="popoverRef" @onmouseenter="HandleMouseEnter"
       @onmouseleave="HandleMouseLeave">
    <div class="flex items-start justify-between gap-3">
      <div>
        <h3 class="text-sm font-semibold text-white">@CurrentPet.Name</h3>
        <p class="text-xs text-slate-400">@CurrentPet.Bio</p>
      </div>
    </div>

    <div class="mt-4 relative">
      <img src="@CurrentSlide" alt="@CurrentPet.Name" class="h-64 w-96 rounded-2xl object-cover" />
    </div>


  </div>
}

@code {
  [Parameter] public bool IsOpen { get; set; }
  [Parameter] public PetPreviewData? CurrentPet { get; set; }
  [Parameter] public string PopoverStyle { get; set; } = "";
  [Parameter] public EventCallback OnClose { get; set; }

  private ElementReference popoverRef;
  private int SlideIndex { get; set; }
  private int ActiveDot => SlideIndex % 3;

  private string CurrentSlide =>
      CurrentPet?.Images[SlideIndex % CurrentPet.Images.Count] ?? "";

  private void NextSlide()
  {
    if (CurrentPet is null || CurrentPet.Images.Count == 0) return;
    SlideIndex = (SlideIndex + 1) % CurrentPet.Images.Count;
  }

  private void PreviousSlide()
  {
    if (CurrentPet is null || CurrentPet.Images.Count == 0) return;
    SlideIndex = (SlideIndex - 1 + CurrentPet.Images.Count) % CurrentPet.Images.Count;
  }

  private Task Close() => OnClose.InvokeAsync();

  private Task HandleMouseEnter() => Task.CompletedTask;
  private Task HandleMouseLeave() => Task.CompletedTask;
}