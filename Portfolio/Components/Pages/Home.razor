@page "/"

<PageTitle>Home</PageTitle>

<div class="min-h-screen bg-slate-950 text-slate-100">
  <div class="mx-auto max-w-7xl px-6 py-10 lg:px-8">
    <!-- Hero -->
    <section class="rounded-3xl border border-slate-800 bg-slate-900/60 p-8 shadow-xl shadow-black/20 backdrop-blur">
      <div class="grid gap-8 lg:grid-cols-[1.5fr_1fr] lg:items-center">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-400">
            Full-Stack Systems & Data Engineer
          </p>

          <h1 class="mt-4 text-4xl font-bold tracking-tight text-white sm:text-5xl outline-none focus:outline-none">
            Hi, I’m Julio Gonzalez Garcia.
        </h1>

          <p class="mt-5 max-w-2xl text-lg leading-8 text-slate-300">
            I build reliable web applications, automation tools, and data-driven systems
            with a focus on clarity, maintainability, and practical impact.
          </p>

          <p class="mt-4 max-w-2xl text-slate-400">
            My background includes full-stack development, SQL Server and Oracle environments,
            system analysis, and workflow automation across business-critical applications.
          </p>

          <div class="mt-8 flex flex-wrap gap-3">
            <a href="/about"
               class="rounded-xl bg-cyan-500 px-5 py-3 font-semibold text-slate-950 transition hover:bg-cyan-400">
              About Me
            </a>
            <a href="/projects"
               class="rounded-xl border border-slate-700 bg-slate-800 px-5 py-3 font-semibold text-slate-100 transition hover:bg-slate-700">
              Projects
            </a>
            <a href="/resume"
               class="rounded-xl border border-slate-700 bg-slate-800 px-5 py-3 font-semibold text-slate-100 transition hover:bg-slate-700">
              Resume
            </a>
          </div>
        </div>

        <div class="rounded-2xl border border-slate-800 bg-slate-950/70 p-5">
          <div class="flex items-center justify-between">
            <h2 class="text-sm font-semibold uppercase tracking-[0.25em] text-slate-400">
              Quick Profile
            </h2>
            <span class="rounded-full bg-emerald-500/10 px-3 py-1 text-xs font-semibold text-emerald-400">
              Available for opportunities
            </span>
          </div>

          <dl class="mt-6 space-y-4">
            @foreach (var item in ProfileStats)
            {
              <div
                class="flex items-start justify-between gap-4 border-b border-slate-800 pb-4 last:border-b-0 last:pb-0">
                <dt class="text-sm text-slate-400">@item.Label</dt>
                <dd class="text-right text-sm font-semibold text-white">@item.Value</dd>
              </div>
            }
          </dl>
        </div>
      </div>
    </section>

    <!-- Stats -->
    <section class="mt-10">
      <div class="grid gap-4 sm:grid-cols-2 xl:grid-cols-4">
        @foreach (var stat in ImpactStats)
        {
          <div class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6 shadow-lg shadow-black/10">
            <p class="text-sm font-medium text-slate-400">@stat.Label</p>
            <p class="mt-3 text-3xl font-bold text-white">@stat.Value</p>
            <p class="mt-2 text-sm leading-6 text-slate-400">@stat.Description</p>
          </div>
        }
      </div>
    </section>

    <!-- Skills -->
    <section class="mt-12">
      <SkillsMarquee Skills="SkillList" />
    </section>

    <!-- Featured Projects -->
    <section class="mt-12">
      <div class="flex items-end justify-between gap-4">
        <div>
          <h2 class="text-2xl font-bold tracking-tight text-white">Featured Projects</h2>
          <p class="mt-2 text-slate-400">A few projects that reflect the kind of work I enjoy building.</p>
        </div>
      </div>

      <div class="mt-6 grid gap-4 lg:grid-cols-2">
        @foreach (var project in FeaturedProjects)
        {
          <article class="rounded-2xl border border-slate-800 bg-slate-900/60 p-6">
            <div class="flex items-start justify-between gap-4">
              <div>
                <h3 class="text-xl font-semibold text-white">@project.Title</h3>
                <p class="mt-2 text-sm text-cyan-400">@project.Stack</p>
              </div>
              <span class="rounded-full bg-slate-800 px-3 py-1 text-xs font-medium text-slate-300">
                @project.Status
              </span>
            </div>

            <p class="mt-4 leading-7 text-slate-300">@project.Description</p>

            <div class="mt-5 flex flex-wrap gap-2">
              @foreach (var tag in project.Tags)
              {
                <span class="rounded-full border border-slate-700 bg-slate-950 px-3 py-1 text-xs text-slate-400">
                  @tag
                </span>
              }
            </div>
          </article>
        }
      </div>
    </section>

    <!-- About preview -->
    <section class="mt-12 rounded-3xl border border-slate-800 bg-slate-900/60 p-8">
      <h2 class="text-2xl font-bold tracking-tight text-white">What I’m Building</h2>
      <p class="mt-4 max-w-3xl leading-7 text-slate-300">
        I’m building this portfolio to showcase personal projects, technical experiments, and examples
        of how I approach software development. Much of my professional work has been internal or
        business-focused, so this site is a place to present that experience in a more public way.
      </p>
    </section>
  </div>
</div>

@code {
  private readonly List<ProfileItem> ProfileStats =
  [
    new("Focus", "Full-Stack + Data Systems"),
    new("Primary Stack", "C#, .NET, SQL, Python"),
    new("Portfolio Style", "Technical / Dashboard"),
  ];

  private readonly List<ImpactStat> ImpactStats =
  [
    new("Realtime Systems", "WebSockets / SSE", "Delivered live status and interaction experiences."),
  ];

  private readonly List<string> SkillList =
    [
      "C#",
      ".NET",
      "Blazor",
      "Python",
      "SQL",
      "PowerShell",
      "Bash",
      "TypeScript",
      "React",
      "Next.js",
      "Node.js",
      "SQL Server",
      "Oracle",
      "SQLite",
      "Docker",
      "IIS"
  ];

  private readonly List<FeaturedProject> FeaturedProjects =
  [
    new(
        "Real-Time System Status Dashboard",
        "Next.js / SSE / SQL Server",
        "A live monitoring dashboard that pushes status updates to connected clients without refreshes.",
        "Active",
        ["Realtime", "Monitoring", "Internal Tool", "Automation"]
    ),
    new(
        "Full-Stack ID Card Creation System",
        "Python / CustomTkinter / SQLite / REST API",
        "A standalone desktop app with drag-and-drop layout tools, barcode generation, and template syncing.",
        "Completed",
        ["Desktop App", "API", "SQLite", "Packaging"]
    )
  ];

  private record ProfileItem(string Label, string Value);
  private record ImpactStat(string Label, string Value, string Description);
  private record SkillGroup(string Title, string[] Skills);
  private record FeaturedProject(string Title, string Stack, string Description, string Status, string[] Tags);
}