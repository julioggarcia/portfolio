@page "/timeline";

<div class="min-h bg-slate-950 text-slate-100 rounded-[calc(theme(borderRadius.lg)-1px)]">
  <div class="mx-auto max-w-7xl px-6 py-12 lg:px-8">
    <!-- Timeline -->
    <section class="mt-8">
      <div class="flex items-end justify-between gap-4">
        <div>
          <p class="text-sm font-medium uppercase tracking-[0.3em] text-cyan-400">
            Timeline
          </p>
          <h2 class="mt-3 text-3xl font-bold tracking-tight text-white">
            A quick look at my background
          </h2>
        </div>
      </div>

      <div class="mt-8 space-y-6">
        @foreach (var item in TimelineHistory)
        {
          <article
            class="grid gap-4 rounded-2xl border border-slate-800 bg-slate-900/60 p-6 lg:grid-cols-[180px_1fr] lg:gap-8 mt-4">
            <div>
              <p class="text-sm font-semibold uppercase tracking-[0.2em] text-cyan-400">
                @item.Date
              </p>
            </div>

            <div>
              <h3 class="text-xl font-semibold text-white">@item.Title</h3>
              <p class="mt-2 leading-7 text-slate-300">@item.Description</p>
            </div>
          </article>
        }
      </div>
    </section>
  </div>
</div>

@code {
  private readonly List<TimelineItem> TimelineHistory =[
    new(
      "Dec 2023 – Present",
      "County of Santa Barbara",
      "EDP Systems and Programming Analyst I. Focused on full-stack application development, .NET refactoring, database engineering, automation, and systems integration."
    ),
    new(
      "Sep 2021 – Dec 2023",
      "Santa Maria Joint Union High School",
      "Student Information Systems Analyst. Supported and maintained large-scale SIS environments, worked on data integration, reporting, troubleshooting, and process improvements."
    ),
    new(
      "Jun 2021",
      "California Polytechnic State University",
      "Earned a Bachelor of Science in Computer Science with coursework in software engineering, databases, algorithms, and technical writing."
    )
];

  private record TimelineItem(string Date, string Title, string Description);
}