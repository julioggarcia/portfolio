<div class="overflow-hidden p-3">
    <div class="flex items-center gap-4">
        <h3 class="text-lg font-semibold text-white">Core Skills</h3>
        <p class="text-sm text-slate-400">Tools and technologies I use regularly</p>
    </div>

    <div class="mt-6 relative">
        <div class="skills-marquee flex w-max gap-3 whitespace-nowrap">
            @foreach (var skill in AllSkills.Concat(AllSkills))
            {
                <span class="rounded-full border border-slate-700 bg-slate-950 px-4 py-2 text-sm text-slate-300">
                    @skill
                </span>
            }
        </div>
    </div>
</div>

@code {
    [Parameter]
    public IEnumerable<string> Skills { get; set; } = [];

    private List<string> AllSkills => Skills.ToList();
}